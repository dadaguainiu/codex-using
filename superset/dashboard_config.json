        "groupby": ["language"]
      }
    },
    {
      "id": 3,
      "slice_name": "仓库排行",
      "viz_type": "table",
      "params": {
        "datasource": "dws_repo_hourly_agg",
        "metrics": ["current_stars", "stars_increment"],
        "groupby": ["repo_name", "language"],
        "order_by": "current_stars",
        "row_limit": 100
      }
    },
    {
      "id": 4,
      "slice_name": "全局指标",
      "viz_type": "big_number_total",
      "params": {
        "datasource": "ads_global_metrics_1d",
